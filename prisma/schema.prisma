// prisma/schema.prisma — HubYa
// Esquema base según ARCHITECTURE.md + columnas de fundadores (SPEC-hubs-fundadores.md)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────

enum HubStatus {
  active
  pending
  rejected
  archived
}

enum MembershipRole {
  vecino
  proveedor_producto
  proveedor_servicio
  admin_hub
  super_admin
}

enum CategoryType {
  product
  service
}

enum PriceType {
  fixed
  per_hour
  per_unit
  per_project
  on_request
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum OrderStatus {
  pending
  confirmed
  preparing
  in_progress
  delivered
  completed
  cancelled
  disputed
}

enum TransactionStatus {
  pending
  approved
  in_process
  rejected
  refunded
  cancelled
}

enum RoundStatus {
  draft
  open
  closed
  settled
}

enum RoundTxType {
  contribution
  purchase
  adjustment
  settlement
}

enum NotificationStatus {
  pending
  sent
  failed
  cancelled
}

enum NotificationChannel {
  whatsapp
  email
  push
  sms
}

// ── HUBS ─────────────────────────────────────────────────
// La raíz de todo. Casi todas las queries filtran por hub_id.
// status/createdByUserId/refCode son adiciones de la spec de Hubs Fundadores.

model Hub {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique @db.VarChar(100)
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  address         String?   @db.Text
  lat             Float?
  lng             Float?
  radiusMeters    Int       @default(1000)
  timezone        String    @default("America/Argentina/Buenos_Aires") @db.VarChar(50)
  settings        Json      @default("{}")
  status          HubStatus @default(active)
  createdByUserId String?   @db.Uuid
  refCode         String?   @unique @db.VarChar(20)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime? @db.Timestamptz(6)

  createdByUser    User?             @relation("HubFounder", fields: [createdByUserId], references: [id])
  memberships      Membership[]
  categories       Category[]
  offerings        Offering[]
  conversations    Conversation[]
  orders           Order[]
  transactions     Transaction[]
  collectiveRounds CollectiveRound[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  termsAcceptances TermsAcceptance[]

  @@map("hubs")
}

// ── USERS ─────────────────────────────────────────────────
// Una persona, identificada por su número de WhatsApp.
// El mismo usuario puede tener múltiples roles en múltiples hubs (via memberships).

model User {
  id                String    @id @default(uuid()) @db.Uuid
  phoneNumber       String    @unique @db.VarChar(20)
  fullName          String?   @db.VarChar(200)
  email             String?   @db.VarChar(200)
  preferredLanguage String    @default("es") @db.Char(2)
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime? @db.Timestamptz(6)

  memberships       Membership[]
  conversations     Conversation[]
  orders            Order[]
  transactions      Transaction[]
  termsAcceptances  TermsAcceptance[]
  roundParticipants RoundParticipant[]
  roundMovements    RoundMovement[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  foundedHubs       Hub[]             @relation("HubFounder")

  @@map("users")
}

// ── MEMBERSHIPS ───────────────────────────────────────────
// El rol de un usuario en un hub. Un usuario puede tener varios roles en varios hubs.
// metadata.founder = true indica que este vecino fundó el hub.
// metadata.interested_in_pending = true indica que se sumó a un hub pendiente.

model Membership {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  hubId     String         @db.Uuid
  role      MembershipRole
  active    Boolean        @default(true)
  joinedAt  DateTime       @default(now()) @db.Timestamptz(6)
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id])
  hub      Hub       @relation(fields: [hubId], references: [id])
  provider Provider?

  @@unique([userId, hubId, role])
  @@map("memberships")
}

// ── TERMS ACCEPTANCES ─────────────────────────────────────

model TermsAcceptance {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  hubId        String?  @db.Uuid
  termsVersion String   @db.VarChar(20)
  acceptedAt   DateTime @default(now()) @db.Timestamptz(6)
  acceptedIp   String?  @db.VarChar(45)
  acceptedVia  String?  @db.VarChar(20)
  metadata     Json     @default("{}")

  user User  @relation(fields: [userId], references: [id])
  hub  Hub?  @relation(fields: [hubId], references: [id])

  @@map("terms_acceptances")
}

// ── CATEGORIES ────────────────────────────────────────────

model Category {
  id           String       @id @default(uuid()) @db.Uuid
  hubId        String?      @db.Uuid
  type         CategoryType
  parentId     String?      @db.Uuid
  slug         String       @db.VarChar(100)
  name         String       @db.VarChar(200)
  description  String?      @db.Text
  icon         String?      @db.VarChar(100)
  displayOrder Int          @default(0)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(6)

  hub       Hub?       @relation(fields: [hubId], references: [id])
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  offerings Offering[]

  @@map("categories")
}

// ── PROVIDERS ─────────────────────────────────────────────
// El perfil comercial de un usuario con rol proveedor_* en un hub.

model Provider {
  id            String    @id @default(uuid()) @db.Uuid
  membershipId  String    @unique @db.Uuid
  businessName  String    @db.VarChar(200)
  description   String?   @db.Text
  logoUrl       String?   @db.Text
  phoneBusiness String?   @db.VarChar(20)
  verified      Boolean   @default(false)
  verifiedAt    DateTime? @db.Timestamptz(6)
  ratingAvg     Decimal?  @db.Decimal(3, 2)
  ratingCount   Int       @default(0)
  active        Boolean   @default(true)
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  membership Membership @relation(fields: [membershipId], references: [id])
  offerings  Offering[]
  orders     Order[]

  @@map("providers")
}

// ── OFFERINGS ─────────────────────────────────────────────
// Productos o servicios que un proveedor ofrece dentro de un hub.

model Offering {
  id          String       @id @default(uuid()) @db.Uuid
  providerId  String       @db.Uuid
  hubId       String       @db.Uuid
  categoryId  String?      @db.Uuid
  type        CategoryType
  name        String       @db.VarChar(300)
  description String?      @db.Text
  price       Decimal?     @db.Decimal(12, 2)
  priceType   PriceType    @default(fixed)
  currency    String       @default("ARS") @db.Char(3)
  available   Boolean      @default(true)
  stock       Int?
  images      Json         @default("[]")
  attributes  Json         @default("{}")
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?    @db.Timestamptz(6)

  provider   Provider    @relation(fields: [providerId], references: [id])
  hub        Hub         @relation(fields: [hubId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("offerings")
}

// ── CONVERSATIONS ─────────────────────────────────────────
// Estado del flujo del bot. Nunca en memoria — siempre en la base (Regla 1).

model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  hubId          String?   @db.Uuid
  currentFlow    String?   @db.VarChar(100)
  currentStep    String?   @db.VarChar(100)
  context        Json      @default("{}")
  lastInboundAt  DateTime? @db.Timestamptz(6)
  lastOutboundAt DateTime? @db.Timestamptz(6)
  expiresAt      DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id])
  hub      Hub?      @relation(fields: [hubId], references: [id])
  messages Message[]

  @@map("conversations")
}

// ── MESSAGES ──────────────────────────────────────────────
// Historial completo de WhatsApps. metaMessageId garantiza idempotencia.

model Message {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @db.Uuid
  direction      MessageDirection
  metaMessageId  String?          @unique @db.VarChar(200)
  type           String?          @db.VarChar(50)
  content        String?          @db.Text
  payload        Json?
  status         MessageStatus    @default(queued)
  error          String?          @db.Text
  createdAt      DateTime         @default(now()) @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

// ── ORDERS ────────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber String      @unique @db.VarChar(20)
  hubId       String      @db.Uuid
  buyerUserId String      @db.Uuid
  providerId  String      @db.Uuid
  status      OrderStatus @default(pending)
  subtotal    Decimal     @db.Decimal(12, 2)
  fee         Decimal     @default(0) @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  currency    String      @default("ARS") @db.Char(3)
  notes       String?     @db.Text
  metadata    Json        @default("{}")
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  hub          Hub          @relation(fields: [hubId], references: [id])
  buyerUser    User         @relation(fields: [buyerUserId], references: [id])
  provider     Provider     @relation(fields: [providerId], references: [id])
  items        OrderItem[]
  transactions Transaction[]

  @@map("orders")
}

// ── ORDER ITEMS ───────────────────────────────────────────
// nameSnapshot y priceSnapshot congelan el nombre y precio al momento de la compra.

model OrderItem {
  id            String  @id @default(uuid()) @db.Uuid
  orderId       String  @db.Uuid
  offeringId    String  @db.Uuid
  nameSnapshot  String  @db.VarChar(300)
  priceSnapshot Decimal @db.Decimal(12, 2)
  quantity      Int     @default(1)
  subtotal      Decimal @db.Decimal(12, 2)
  metadata      Json    @default("{}")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  offering Offering @relation(fields: [offeringId], references: [id])

  @@map("order_items")
}

// ── TRANSACTIONS ──────────────────────────────────────────

model Transaction {
  id                   String            @id @default(uuid()) @db.Uuid
  orderId              String?           @db.Uuid
  userId               String            @db.Uuid
  hubId                String            @db.Uuid
  amount               Decimal           @db.Decimal(12, 2)
  currency             String            @default("ARS") @db.Char(3)
  status               TransactionStatus @default(pending)
  paymentMethod        String?           @db.VarChar(50)
  provider             String            @default("mercadopago") @db.VarChar(50)
  providerPaymentId    String?           @unique @db.VarChar(200)
  providerPreferenceId String?           @db.VarChar(200)
  rawResponse          Json?
  createdAt            DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime          @updatedAt @db.Timestamptz(6)

  order Order? @relation(fields: [orderId], references: [id])
  user  User   @relation(fields: [userId], references: [id])
  hub   Hub    @relation(fields: [hubId], references: [id])

  @@map("transactions")
}

// ── COLLECTIVE ROUNDS ─────────────────────────────────────

model CollectiveRound {
  id          String      @id @default(uuid()) @db.Uuid
  hubId       String      @db.Uuid
  name        String      @db.VarChar(200)
  description String?     @db.Text
  status      RoundStatus @default(draft)
  startsAt    DateTime?   @db.Timestamptz(6)
  endsAt      DateTime?   @db.Timestamptz(6)
  metadata    Json        @default("{}")
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  hub          Hub               @relation(fields: [hubId], references: [id])
  participants RoundParticipant[]
  movements    RoundMovement[]

  @@map("collective_rounds")
}

model RoundParticipant {
  id       String   @id @default(uuid()) @db.Uuid
  roundId  String   @db.Uuid
  userId   String   @db.Uuid
  joinedAt DateTime @default(now()) @db.Timestamptz(6)

  round CollectiveRound @relation(fields: [roundId], references: [id])
  user  User            @relation(fields: [userId], references: [id])

  @@unique([roundId, userId])
  @@map("round_participants")
}

model RoundMovement {
  id               String      @id @default(uuid()) @db.Uuid
  roundId          String      @db.Uuid
  userId           String      @db.Uuid
  type             RoundTxType
  amount           Decimal     @db.Decimal(12, 2)
  description      String?     @db.Text
  referenceOrderId String?     @db.Uuid
  createdAt        DateTime    @default(now()) @db.Timestamptz(6)

  round CollectiveRound @relation(fields: [roundId], references: [id])
  user  User            @relation(fields: [userId], references: [id])

  @@map("round_movements")
}

// ── NOTIFICATIONS ─────────────────────────────────────────
// Cola persistente. El worker de BullMQ las consume; nunca se envían sincrónicamente.

model Notification {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @db.Uuid
  hubId        String?             @db.Uuid
  channel      NotificationChannel
  template     String              @db.VarChar(100)
  payload      Json
  scheduledFor DateTime            @default(now()) @db.Timestamptz(6)
  sentAt       DateTime?           @db.Timestamptz(6)
  status       NotificationStatus  @default(pending)
  attempts     Int                 @default(0)
  lastError    String?             @db.Text
  createdAt    DateTime            @default(now()) @db.Timestamptz(6)

  user User  @relation(fields: [userId], references: [id])
  hub  Hub?  @relation(fields: [hubId], references: [id])

  @@map("notifications")
}

// ── AUDIT LOG ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  hubId      String?  @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.Uuid
  changes    Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])
  hub  Hub?  @relation(fields: [hubId], references: [id])

  @@map("audit_logs")
}
